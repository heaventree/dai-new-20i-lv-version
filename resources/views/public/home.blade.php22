<section class="py-24 bg-white">
    <div class="container mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-extrabold text-center mb-14" style="font-family:'Manrope',sans-serif; letter-spacing:-0.02em; color: hsl(215deg 81% 14%);">
