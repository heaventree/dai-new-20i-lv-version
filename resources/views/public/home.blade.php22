            <div id="testimonials-grid" class="grid gap-6">
                {{-- Cards rendered by JS from JSON --}}
            </div>

            {{-- Controls --}}
            @if($testimonials->count() > 3)
            <div class="flex items-center justify-center gap-4 mt-10">
                <button id="t-prev" class="w-9 h-9 rounded-full border flex items-center justify-center transition-colors" style="border-color: rgba(11,49,104,0.2); color: hsl(215deg 81% 14%);" aria-label="Previous testimonials">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                </button>
                <div id="t-dots" class="flex gap-2"></div>
                <button id="t-next" class="w-9 h-9 rounded-full border flex items-center justify-center transition-colors" style="border-color: rgba(11,49,104,0.2); color: hsl(215deg 81% 14%);" aria-label="Next testimonials">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </button>
            </div>
            @endif
        </div>

        <script>
(function() {
    var items = @json($testimonials->values());
    var VISIBLE = 3;
    var active  = 0;
    var timer   = null;
    var grid    = document.getElementById('testimonials-grid');
    var dotsEl  = document.getElementById('t-dots');
    var prevBtn = document.getElementById('t-prev');
    var nextBtn = document.getElementById('t-next');

    function star(yellow) {
        return '<svg style="width:1rem;height:1rem;color:' + (yellow ? '#ffcf00' : '#d1d5db') + ';fill:currentColor;" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>';
    }

    function renderCard(t) {
        var hl = t.highlight;
        var bg   = hl ? 'background:hsl(215deg 81% 23%);box-shadow:0 12px 32px rgba(25,28,29,0.12);' : 'background:white;border:1px solid hsl(215deg 20% 92%);box-shadow:0 4px 12px rgba(25,28,29,0.06);';
        var qc   = hl ? 'color:rgba(255,255,255,0.85);' : 'color:hsl(215deg 70% 12%);';
        var nc   = hl ? 'color:#fff;' : 'color:hsl(215deg 81% 23%);';
        var bt   = hl ? 'border-top:1px solid rgba(255,255,255,0.15);' : 'border-top:1px solid hsl(215deg 20% 92%);';
        var stars = Array.from({length: t.stars || 5}).map(function(){ return star(true); }).join('');
        return '<div class="rounded-xl p-7 flex flex-col gap-4 transition-transform duration-200 hover:-translate-y-1" style="' + bg + '">'
            + '<div class="flex gap-0.5">' + stars + '</div>'
            + '<blockquote class="text-base leading-relaxed flex-1" style="' + qc + '">&ldquo;' + t.quote + '&rdquo;</blockquote>'
            + '<p class="text-base font-bold" style="margin-top:1.5rem;padding-top:1rem;' + bt + nc + '">&mdash; ' + t.name + ', ' + t.location + '</p>'
            + '</div>';
    }

    function render() {
        var count = items.length;
        var visibleCount = count === 2 ? 2 : Math.min(VISIBLE, count);
        var show  = visibleCount;
        var html  = '';
        for (var i = 0; i < show; i++) {
            html += renderCard(items[(active + i) % count]);
        }
        if (grid) {
            grid.innerHTML = html;
            grid.className = 'grid gap-6 ' + (
                visibleCount === 1 ? 'grid-cols-1 max-w-xl mx-auto' :
                visibleCount === 2 ? 'grid-cols-1 md:grid-cols-2' :
                'grid-cols-1 md:grid-cols-3'
            );
        }

        if (dotsEl) {
            dotsEl.innerHTML = '';
            for (var j = 0; j < count; j++) {
                var d = document.createElement('button');
                d.style.cssText = 'width:0.5rem;height:0.5rem;border-radius:9999px;background:' + (j === active ? 'hsl(215deg 81% 23%)' : 'hsl(215deg 20% 80%)') + ';border:none;padding:0;cursor:pointer;';
                d.setAttribute('aria-label', 'Go to testimonial ' + (j + 1));
                (function(idx){ d.addEventListener('click', function(){ active = idx; render(); resetTimer(); }); })(j);
                dotsEl.appendChild(d);
            }
        }
    }

    function resetTimer() {
        if (timer) clearInterval(timer);
        if (items.length <= VISIBLE) return;
        timer = setInterval(function() {
            active = (active + 1) % items.length;
            render();
        }, 4500);
    }

    if (prevBtn) prevBtn.addEventListener('click', function() {
        active = (active - 1 + items.length) % items.length;
        render(); resetTimer();
        this.style.background = 'hsl(215deg 81% 23%)'; this.style.color = '#fff';
        var self = this; setTimeout(function(){ self.style.background = ''; self.style.color = 'hsl(215deg 81% 14%)'; }, 200);
    });
    if (nextBtn) nextBtn.addEventListener('click', function() {
        active = (active + 1) % items.length;
        render(); resetTimer();
        this.style.background = 'hsl(215deg 81% 23%)'; this.style.color = '#fff';
        var self = this; setTimeout(function(){ self.style.background = ''; self.style.color = 'hsl(215deg 81% 14%)'; }, 200);
    });

    render();
    resetTimer();
})();
        </script>
    </div>
</section>
@endif

