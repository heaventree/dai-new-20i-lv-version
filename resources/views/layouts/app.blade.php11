    <style>
        /* ── Base — exact match to React design system ── */
        html { font-size: 16px; }
        body {
            font-family: 'Inter', ui-sans-serif, system-ui, sans-serif !important;
            font-size: 1rem;
            line-height: 1.8;
            color: hsl(215deg 70% 12%);
            background: hsl(210deg 17% 98%);
        }
        h1, h2, h3, h4, h5, h6 {
            font-family: 'Manrope', ui-sans-serif, system-ui, sans-serif !important;
            letter-spacing: -0.02em;
            line-height: 1.2;
            color: hsl(215deg 81% 23%);
        }

        /* ── Text sizes — exact match to React overrides ── */
        .text-xs   { font-size: 16px !important; line-height: 24px !important; }
        .text-sm   { font-size: 17px !important; line-height: 25px !important; }
        .text-base { font-size: 17px !important; line-height: 25px !important; }

        /* Nav links: 16px to match React nav override */
        .nav-link { font-size: 16px; font-weight: 500; color: hsl(215deg 20% 40%); transition: color 0.15s; }
        .nav-link:hover  { color: hsl(215deg 81% 23%); }
        .nav-link.active { color: hsl(215deg 81% 23%); font-weight: 600; }

        /* Muted text — exact match to React: hsl(215deg 18.97% 31.37%) = #414d5f */
        .text-muted,
        .text-muted-foreground { color: hsl(215deg 18.97% 31.37%); }

        /* ── Remap Tailwind neutral grey → navy-tinted (matches React palette) ── */
        /* React uses navy-hued greys everywhere instead of neutral grey */
        .text-gray-900 { color: hsl(215deg 70% 12%) !important; }
        .text-gray-800 { color: hsl(215deg 40% 20%) !important; }
        .text-gray-700 { color: hsl(215deg 25% 28%) !important; }
        .text-gray-600 { color: hsl(215deg 18.97% 31.37%) !important; }
        .text-gray-500 { color: hsl(215deg 18.97% 38%) !important; }
        .text-gray-400 { color: hsl(215deg 14% 52%) !important; }
        .text-gray-300 { color: hsl(215deg 10% 66%) !important; }

        /* Section / card backgrounds — surface-low matches React */
        .bg-gray-50  { background-color: hsl(210deg 11% 96%) !important; }
        .bg-gray-100 { background-color: hsl(215deg 20% 93%) !important; }
        .bg-gray-200 { background-color: hsl(215deg 18% 88%) !important; }

        /* Border greys — keep subtle navy tint */
        .border-gray-100 { border-color: hsl(215deg 20% 93%) !important; }
        .border-gray-200 { border-color: hsl(215deg 18% 88%) !important; }
        .divide-gray-100 > * + * { border-color: hsl(215deg 20% 93%) !important; }

        /* ── Buttons ── */
        .btn-primary { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.75rem; border-radius: 0.75rem; font-weight: 700; font-size: 0.9375rem; background: #ffcf00; color: #231b00; box-shadow: 0 4px 16px rgba(255,207,0,0.35); transition: filter 0.15s, transform 0.1s; }
        .btn-primary:hover { filter: brightness(1.05); }
        .btn-primary:active { transform: scale(0.97); }
        .btn-outline-white { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.75rem; border-radius: 0.75rem; font-weight: 600; font-size: 0.9375rem; color: rgba(255,255,255,0.9); transition: color 0.15s; }
        .btn-outline-white:hover { color: #fff; }
        .btn-navy { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem; border-radius: 0.75rem; font-weight: 700; font-size: 0.9375rem; background: hsl(215deg 81% 23%); color: #fff; transition: filter 0.15s, transform 0.1s; }
        .btn-navy:hover { filter: brightness(1.1); }
        .btn-navy:active { transform: scale(0.97); }
        .btn-outline-dark { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem; border-radius: 0.75rem; font-weight: 700; font-size: 0.9375rem; border: 2px solid rgba(35,27,0,0.35); color: #231b00; transition: background 0.15s, transform 0.1s; }
        .btn-outline-dark:hover { background: rgba(0,0,0,0.08); }
        .btn-outline-dark:active { transform: scale(0.97); }
        .step-card { background: #fff; border-radius: 0.75rem; padding: 1.5rem; box-shadow: 0 4px 12px rgba(25,28,29,0.06); transition: transform 0.2s, box-shadow 0.2s; }
        .step-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(25,28,29,0.1); }
    </style>
