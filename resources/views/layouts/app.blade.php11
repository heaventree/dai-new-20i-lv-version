                        "on-secondary-fixed":       "#231b00",
                        accent:                     "#ffcf00",
                        /* ── Surfaces — matches React design tokens ── */
                        "surface":                  "hsl(210 17% 98%)",
                        "surface-container-lowest": "#ffffff",
                        "surface-container-low":    "hsl(210 11% 96%)",
                        "surface-container":        "hsl(215 20% 93%)",
                        "surface-container-high":   "hsl(200 5% 89%)",
                        /* ── Text — matches React foreground/muted ── */
                        "on-surface":               "hsl(215 70% 12%)",
                        "on-surface-variant":       "hsl(215 20% 44%)",
                        "outline-variant":          "hsl(215 20% 78%)",
                        "outline":                  "hsl(215 20% 60%)",
                        "muted-foreground":         "hsl(215 19% 31%)",
                        "surface-low":              "hsl(210 11% 96%)",
                        "error":                    "hsl(0 72% 51%)",
                    },
                    fontFamily: {
                        display:  ["Manrope", "sans-serif"],
                        headline: ["Manrope", "sans-serif"],
                        body:     ["Inter", "sans-serif"],
