                    colors: {
                        /* ── Primary — matches React hsl(215 81% 23%) = #0b3168 ── */
                        primary:                    "hsl(215 81% 23%)",
                        "primary-dark":             "hsl(215 81% 14%)",
                        "primary-container":        "hsl(215 81% 23%)",
                        "on-primary":               "#ffffff",
                        "on-primary-container":     "rgba(255,255,255,0.85)",
                        /* ── Gold — matches React hsl(48 100% 50%) = #ffcf00 ── */
