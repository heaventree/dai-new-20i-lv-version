APP_NAME="Driver Assessments Ireland"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://dai.ie/dai-laravel/public
ASSET_URL=https://dai.ie/dai-laravel/public

LOG_CHANNEL=stack
LOG_LEVEL=error

# ─── Database (20i MySQL) ─────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password

# ─── Session & Cache (file-based — no Redis needed on 20i) ───────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET=sk_live_...
STRIPE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Google reCAPTCHA v3 (add before go-live) ─────────────────────────────────
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ─── Google Sheets ────────────────────────────────────────────────────────────
# Paste the full service account JSON as a single-line string
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_ID=1hvbRmC5qMUctk0733OK0283nEAvCWyRgLsoZiO0G7mw

# ─── Email / SMTP (20i webmail) ───────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mail.20i.com
MAIL_PORT=465
MAIL_USERNAME=info@driverassessmentsireland.ie
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=info@driverassessmentsireland.ie
MAIL_FROM_NAME="Driver Assessments Ireland"

# Admin contact — receives form notifications
DAI_CONTACT_EMAIL=info@driverassessmentsireland.ie

# ─── Data migration only ──────────────────────────────────────────────────────
# Set this ONLY when running: php artisan dai:migrate-from-postgres
# Format: postgres://user:password@host:5432/dbname
POSTGRES_URL=
